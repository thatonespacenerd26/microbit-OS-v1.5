# ==============================================================================
# 3. TM1637 HARDWARE DRIVER (FULL UNROLLED IMPLEMENTATION)
# ==============================================================================
# This class handles low-level I2C-like communication for 4-digit displays.
class TM1637Driver:
    def __init__(self, clk=pin1, dio=pin2, brightness=7):
        """
        Initializes the TM1637 external display driver.
        Requires explicit clock (clk) and data (dio) pins.
        """
        self.clk = clk
        self.dio = dio
        self.brightness = brightness
        
        # Hexadecimal representations for standard 7-segment numbers 0-9
        self.segment_map = [
            0x3F, # 0
            0x06, # 1
            0x5B, # 2
            0x4F, # 3
            0x66, # 4
            0x6D, # 5
            0x7D, # 6
            0x07, # 7
            0x7F, # 8
            0x6F  # 9
        ]
        
        self.initialize_hardware()

    def initialize_hardware(self):
        """Prepares pins and turns on the display."""
        self.clk.write_digital(1)
        self.dio.write_digital(1)
        self.power_on()
        self.clear_display()

    def _start_condition(self):
        """Signals the start of data transmission."""
        self.dio.write_digital(0)
        self.clk.write_digital(0)

    def _stop_condition(self):
        """Signals the end of data transmission."""
        self.clk.write_digital(1)
        self.dio.write_digital(1)

    def _write_byte(self, byte_data):
        """Transmits 8 bits of data serially."""
        for bit_index in range(8):
            self.clk.write_digital(0)
            bit_value = (byte_data >> bit_index) & 1
            self.dio.write_digital(bit_value)
            self.clk.write_digital(1)
            self.clk.write_digital(0)
            
        # Await hardware acknowledgment clock cycle
        self.clk.write_digital(0)
        self.dio.write_digital(1)
        self.clk.write_digital(1)
        self.clk.write_digital(0)

    def power_on(self):
        """Wakes the TM1637 and applies the brightness setting."""
        self._start_condition()
        self._write_byte(0x88 + self.brightness) 
        self._stop_condition()

    def power_off(self):
        """Puts the TM1637 into low-power sleep mode."""
        self._start_condition()
        self._write_byte(0x80) 
        self._stop_condition()

    def clear_display(self):
        """Writes 0x00 (blank) to all four digit addresses."""
        self._start_condition()
        self._write_byte(0x40) # Command: Auto-increment address
        self._stop_condition()
        
        self._start_condition()
        self._write_byte(0xC0) # Start at address 00H
        for _ in range(4):
            self._write_byte(0x00) 
        self._stop_condition()

    def display_integer(self, number):
        """Parses an integer (0-9999) and formats it for the display."""
        # Enforce boundary limits
        if number > 9999: number = 9999
        if number < 0: number = 0
            
        # Extract individual digits mathematically
        thousands = (number // 1000) % 10
        hundreds  = (number // 100) % 10
        tens      = (number // 10) % 10
        ones      = number % 10
        
        # Prepare SRAM write command
        self._start_condition()
        self._write_byte(0x40)
        self._stop_condition()
        
        # Write sequential data starting at 0xC0
        self._start_condition()
        self._write_byte(0xC0) 
        
        # Determine leading zero blanking
        if number >= 1000: self._write_byte(self.segment_map[thousands])
        else: self._write_byte(0x00)
            
        if number >= 100: self._write_byte(self.segment_map[hundreds])
        else: self._write_byte(0x00)
            
        if number >= 10: self._write_byte(self.segment_map[tens])
        else: self._write_byte(0x00)
            
        self._write_byte(self.segment_map[ones]) # Always render ones place
        self._stop_condition()


