class LoggerApp:
    """App 0: Visual heartbeat logger."""
    def update(self):
        display.show(IMG_LOGGER)
        current_time = running_time()
        # Create a slow, throbbing blink in the top left corner
        if (current_time // 800) % 2 == 0:
            display.set_pixel(0, 0, 9)
        else:
            display.set_pixel(0, 0, 0)


class SecurityApp:
    """App 1: Alarm system with noise/shake detection."""
    def __init__(self):
        self.is_armed = False
        
    def arm_system(self):
        """Displays arming sequence with countdown."""
        display.scroll("ARMING", delay=80)
        for countdown in range(3, 0, -1):
            display.show(str(countdown))
            music.pitch(880, 200) # Pre-arm beep
            sleep(800)
        display.clear()
        self.is_armed = True

    def update(self):
        """Monitors sensors. If triggered, initiates lockdown."""
        vol = microphone.sound_level()
        shaken = accelerometer.was_gesture('shake')
        
        if shaken or vol > ALARM_SOUND_THRESHOLD:
            self._trigger_alarm()
            
    def _trigger_alarm(self):
        """Locks the system into a wee-woo state until logo is touched."""
        display.scroll("INTRUDER DETECTED", delay=80)
        
        alarm_active = True
        while alarm_active:
            # High pitch phase ("Wee")
            display.show(IMG_SECURITY)
            music.pitch(900, 400, wait=False)
            
            # Poll for exit during first phase
            t_start = running_time()
            while running_time() - t_start < 400:
                if pin_logo.is_touched():
                    alarm_active = False
                    break
            if not alarm_active: break
            
            # Low pitch phase ("Woo")
            display.clear()
            music.pitch(600, 400, wait=False)
            
            # Poll for exit during second phase
            t_start = running_time()
            while running_time() - t_start < 400:
                if pin_logo.is_touched():
                    alarm_active = False
                    break
                    
        # Clean exit from alarm
        self.is_armed = False
        display.clear()


class TiltApp:
    """App 2: Accelerometer balancing tool."""
    def update(self):
        # Fetch raw gravity vectors
        acc_x = accelerometer.get_x()
        acc_y = accelerometer.get_y()
        
        # Scale range (-1024 to 1024) to screen coordinates (0 to 4)
        dot_x = int((acc_x + 1000) / TILT_SENSITIVITY)
        dot_y = int((acc_y + 1000) / TILT_SENSITIVITY)
        
        # Clamp mathematically to prevent screen overflow errors
        dot_x = max(0, min(4, dot_x))
        dot_y = max(0, min(4, dot_y))
        
        if dot_x == 2 and dot_y == 2:
            display.show(Image.YES)
        else:
            display.show(IMG_TILT)
            display.set_pixel(dot_x, dot_y, 9)


class VolumeApp:
    """App 3: Live microphone visualization."""
    def update(self):
        display.show(IMG_VOLUME)
        raw_vol = microphone.sound_level()
        
        # Scale volume to number of active LEDs (0-5)
        active_leds = int(raw_vol / 50)
        active_leds = max(0, min(5, active_leds))
        
        for index in range(5):
            if index < active_leds:
                display.set_pixel(index, 0, 9)
            else:
                # Do not overwrite the underlying music note graphic
                if IMG_VOLUME.get_pixel(index, 0) == 0:
                    display.set_pixel(index, 0, 0)


class DiceApp:
    """App 5: Random number generator with physical roll mechanic."""
    def update(self):
        display.show(IMG_DICE)
        if accelerometer.was_gesture('shake'):
            self._roll_animation()
            
    def _roll_animation(self):
        # Rapid flickering for suspense
        for _ in range(8):
            face = random.randint(1, 6)
            display.show(str(face))
            music.pitch(400, DICE_ANIMATION_DELAYS)
            sleep(DICE_ANIMATION_DELAYS)
        
        # Settle on final outcome
        final = random.randint(1, 6)
        display.show(str(final))
        music.play(['C5:2'])
        sleep(2000) # Pause so user can read result


class ClockApp:
    """App 6: External TM1637 driver interface."""
    def __init__(self):
        self.count = 1
        self.last_tick = running_time()
        
    def update(self, external_display):
        display.show(IMG_CLOCK)
        current_t = running_time()
        
        if (current_t - self.last_tick) > TM1637_TICK_SPEED_MS:
            self.count += 1
            if self.count > 9999:
                self.count = 1
            external_display.display_integer(self.count)
            self.last_tick = current_t


# ==============================================================================
# 5. CORE OPERATING SYSTEM ENGINE
# ==============================================================================

class MicroOS:
    """Master controller managing power, inputs, and app routing."""
    
    def __init__(self):
        # Instantiate Hardware
        self.tm_display = TM1637Driver(clk=pin1, dio=pin2, brightness=7)
        
        # Instantiate Apps
        self.app_logger   = LoggerApp()
        self.app_security = SecurityApp()
        self.app_tilt     = TiltApp()
        self.app_volume   = VolumeApp()
        self.app_dice     = DiceApp()
        self.app_clock    = ClockApp()
        
        # Initialize State
        self.current_idx = APP_LOGGER
        self.in_app_mode = False
        self.last_activity = running_time()

    def boot(self):
        """Initial startup sequence and hardware checks."""
        for _ in range(3):
            display.show(Image.HAPPY)
            sleep(150)
            display.clear()
            sleep(150)
            
        display.show(Image.HAPPY)
        music.play(MELODY_BOOT)
        display.clear()
        
        # Auto-launch into App 0 (Logger)
        self.in_app_mode = True
        self.current_idx = APP_LOGGER
        self._register_activity()

    def _register_activity(self):
        """Refreshes the sleep timer."""
        self.last_activity = running_time()

    def _handle_sleep_state(self):
        """Global interrupt to shut down hardware and wait for wake event."""
        display.clear()
        self.tm_display.power_off()
        
        # Infinite loop until ANY user input is detected
        while True:
            if button_a.was_pressed() or button_b.was_pressed() or \
               pin_logo.is_touched() or accelerometer.was_gesture('shake'):
                
                # Wake sequence
                self._register_activity()
                display.set_pixel(2, 2, 9) # Brief flash to acknowledge wake
                sleep(100)
                display.clear()
                self.tm_display.power_on()
                
                # Clear buffers to prevent accidental app actions
                button_a.was_pressed()
                button_b.was_pressed()
                pin_logo.is_touched()
                accelerometer.was_gesture('shake')
                break
                
            sleep(50) # Maintain low CPU usage while sleeping

    def main_loop(self):
        """Primary execution loop. Runs indefinitely."""
        while True:
            current_time = running_time()

            # --- INPUT POLLING ---
            btn_a = button_a.was_pressed()
            btn_b = button_b.was_pressed()
            logo  = pin_logo.is_touched()
            shake = accelerometer.was_gesture('shake')

            if btn_a or btn_b or logo or shake:
                self._register_activity()

            # --- SLEEP TIMEOUT CHECK ---
            if (current_time - self.last_activity) > INACTIVITY_TIMEOUT_MS:
                self._handle_sleep_state()
                continue # Skip iteration to smoothly resume previous state

            # --- MENU NAVIGATION (OUTSIDE APPS) ---
            if not self.in_app_mode:
                display.show(MENU_ICONS[self.current_idx])
                
                if btn_a:
                    self.current_idx += 1
                    if self.current_idx >= MAX_APPS:
                        self.current_idx = APP_LOGGER
                        
                elif shake:
                    display.scroll(str(temperature()) + "C")
                    
                elif btn_b:
                    self.in_app_mode = True
                    display.clear()
                    
                    # Intercept specific app startup requirements
                    if self.current_idx == APP_SECURITY:
                        self.app_security.arm_system()
                    elif self.current_idx == APP_SLEEP:
                        # Instant trigger of sleep timeout
                        self.last_activity = 0 
                        self.in_app_mode = False 

            # --- APP EXECUTION (INSIDE APPS) ---
            else:
                # Global Exit Handler
                if logo:
                    self.in_app_mode = False
                    display.clear()
                    self._register_activity()
                    continue

                # App Routing Engine
                if self.current_idx == APP_LOGGER:
                    self.app_logger.update()
                    
                elif self.current_idx == APP_SECURITY:
                    self.app_security.update()
                    
                elif self.current_idx == APP_TILT:
                    self.app_tilt.update()
                    
                elif self.current_idx == APP_VOLUME:
                    self.app_volume.update()
                    
                elif self.current_idx == APP_SLEEP:
                    pass # Handled during entry intercept
                    
                elif self.current_idx == APP_DICE:
                    self.app_dice.update()
                    
                elif self.current_idx == APP_TM1637:
                    self.app_clock.update(self.tm_display)

            # --- HARDWARE CYCLE YIELD ---
            sleep(10) # Prevent main loop from freezing micro:bit processor


# ==============================================================================
